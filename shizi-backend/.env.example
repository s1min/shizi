# 服务端口
PORT=8000

# MongoDB 连接串（开发阶段可用本地或 MongoDB Atlas 免费集群）
MONGODB_URI=mongodb://localhost:27017/shizi

# JWT 配置
JWT_SECRET=your-jwt-secret-change-me
JWT_EXPIRES_IN=7d

# 微信小程序配置
WX_APPID=your-wx-appid
WX_APP_SECRET=your-wx-app-secret

# set true only for local debug without real WeChat credentials
WX_LOGIN_MOCK=false

