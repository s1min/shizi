# Production environment template for Docker Compose
# Copy this file to .env and replace all placeholder values before deployment.
# Required variables: JWT_SECRET, WX_APPID, WX_APP_SECRET

JWT_SECRET=replace-with-openssl-rand-hex-32
JWT_EXPIRES_IN=7d
WX_APPID=replace-with-wechat-appid
WX_APP_SECRET=replace-with-wechat-app-secret
